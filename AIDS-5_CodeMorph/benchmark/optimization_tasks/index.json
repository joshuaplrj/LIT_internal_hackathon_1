{
  "tasks": [
    {
      "id": 1,
      "name": "nested_loop_optimization",
      "description": "Optimize O(n\u00b2) algorithm to O(n log n)",
      "original_python": "def find_pairs(arr, target):\n    count = 0\n    for i in range(len(arr)):\n        for j in range(i + 1, len(arr)):\n            if arr[i] + arr[j] == target:\n                count += 1\n    return count\n",
      "optimized_python": "def find_pairs(arr, target):\n    from collections import Counter\n    count = 0\n    seen = Counter()\n    for num in arr:\n        complement = target - num\n        if complement in seen:\n            count += seen[complement]\n        seen[num] += 1\n    return count\n",
      "speedup_factor": 50,
      "test_input": "arr = list(range(10000)); target = 5000",
      "expected_output": "2499"
    },
    {
      "id": 2,
      "name": "string_concatenation",
      "description": "Optimize string concatenation in loop",
      "original_python": "def build_string(n):\n    result = \"\"\n    for i in range(n):\n        result += str(i) + \",\"\n    return result\n",
      "optimized_python": "def build_string(n):\n    return \",\".join(str(i) for i in range(n))\n",
      "speedup_factor": 10,
      "test_input": "n = 100000",
      "expected_output": "Length check"
    },
    {
      "id": 3,
      "name": "list_comprehension",
      "description": "Replace explicit loops with list comprehension",
      "original_python": "def process_data(data):\n    result = []\n    for x in data:\n        if x > 0:\n            result.append(x * 2)\n    return result\n",
      "optimized_python": "def process_data(data):\n    return [x * 2 for x in data if x > 0]\n",
      "speedup_factor": 2,
      "test_input": "data = list(range(-1000, 1000))",
      "expected_output": "List of doubled positive numbers"
    },
    {
      "id": 4,
      "name": "memoization",
      "description": "Add memoization to recursive function",
      "original_python": "def fib(n):\n    if n <= 1:\n        return n\n    return fib(n-1) + fib(n-2)\n",
      "optimized_python": "from functools import lru_cache\n\n@lru_cache(maxsize=None)\ndef fib(n):\n    if n <= 1:\n        return n\n    return fib(n-1) + fib(n-2)\n",
      "speedup_factor": 1000,
      "test_input": "n = 35",
      "expected_output": "9227465"
    },
    {
      "id": 5,
      "name": "numpy_vectorization",
      "description": "Replace Python loops with NumPy operations",
      "original_python": "def compute_distances(points, center):\n    distances = []\n    for p in points:\n        d = ((p[0] - center[0])**2 + (p[1] - center[1])**2)**0.5\n        distances.append(d)\n    return distances\n",
      "optimized_python": "import numpy as np\n\ndef compute_distances(points, center):\n    points = np.array(points)\n    center = np.array(center)\n    return np.sqrt(np.sum((points - center)**2, axis=1))\n",
      "speedup_factor": 100,
      "test_input": "points = [(i, i*2) for i in range(100000)]; center = (50, 100)",
      "expected_output": "Array of distances"
    },
